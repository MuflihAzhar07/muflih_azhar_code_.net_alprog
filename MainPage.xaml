<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VitalGuard.MainPage">

    <Grid>
        <Image Source="https://images.unsplash.com/photo-1545184180-25d471df75bd?ixlib=rb-4.0.3&amp;auto=format&amp;fit=crop&amp;w=1920&amp;q=80" 
               Aspect="AspectFill" />

        <BoxView Color="Black" 
                 Opacity="0.55" />

        <Border BackgroundColor="White"
                Padding="35, 40"
                WidthRequest="400"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16">

            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,8" Radius="15" Opacity="0.2" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="18">

                <Label Text="Sistem Keamanan" 
                       FontSize="28" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center" 
                       TextColor="#1F2937" />

                <Label Text="Portal Akses Masuk" 
                       FontSize="14" 
                       HorizontalOptions="Center" 
                       TextColor="#6B7280" 
                       Margin="0,0,0,10"/>

                <Entry x:Name="EntryUsername" 
                       Placeholder="Masukkan Username" 
                       BackgroundColor="#F3F4F6" 
                       TextColor="Black"
                       PlaceholderColor="#9CA3AF"
                       HeightRequest="45" />

                <Entry x:Name="EntryPassword" 
                       Placeholder="Masukkan Password" 
                       IsPassword="True" 
                       BackgroundColor="#F3F4F6" 
                       TextColor="Black"
                       PlaceholderColor="#9CA3AF"
                       HeightRequest="45" />

                <Button Text="MASUK SISTEM" 
                        FontAttributes="Bold" 
                        BackgroundColor="#2563EB" 
                        TextColor="White" 
                        CornerRadius="8" 
                        HeightRequest="48"
                        Margin="0,10,0,0"
                        Clicked="OnLoginClicked" />

                <Button Text="Belum punya akun? Daftar di sini" 
                        BackgroundColor="Transparent" 
                        TextColor="#2563EB" 
                        TextTransform="None"
                        FontSize="14"
                        Clicked="OnGoToRegisterClicked" />

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>