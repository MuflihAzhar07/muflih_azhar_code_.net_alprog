<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VitalGuard.MedicalRecordPage"
             Title="Database Rekam Medis"
             BackgroundColor="#F3F4F6">

    <VerticalStackLayout Padding="20" Spacing="15">
        
        <FlexLayout JustifyContent="SpaceBetween" AlignItems="Center">
            <VerticalStackLayout>
                <Label Text="🗄️ Database Rekam Medis" FontSize="22" FontAttributes="Bold" TextColor="#1F2937"/>
                <Label Text="Log Riwayat Anomali Pasien (Syarat Tugas E)" FontSize="14" TextColor="#4B5563"/>
            </VerticalStackLayout>
            <Button Text="Kembali ke Dashboard" BackgroundColor="#6B7280" TextColor="White" CornerRadius="8" HeightRequest="40" Clicked="OnBackClicked"/>
        </FlexLayout>

        <Border BackgroundColor="White" Padding="15" StrokeShape="RoundRectangle 12" StrokeThickness="0" VerticalOptions="FillAndExpand">
            <VerticalStackLayout Spacing="10">
                
                <Grid ColumnDefinitions="2*, 1.5*, 1.5*, 2*, 3*" BackgroundColor="#E5E7EB" Padding="10">
                    <Label Grid.Column="0" Text="Waktu" FontAttributes="Bold" TextColor="#374151"/>
                    <Label Grid.Column="1" Text="SpO2" FontAttributes="Bold" TextColor="#374151"/>
                    <Label Grid.Column="2" Text="BPM" FontAttributes="Bold" TextColor="#374151"/>
                    <Label Grid.Column="3" Text="Probabilitas NN" FontAttributes="Bold" TextColor="#374151"/>
                    <Label Grid.Column="4" Text="Status Fuzzy" FontAttributes="Bold" TextColor="#374151"/>
                </Grid>

                <CollectionView x:Name="ListRiwayat" HeightRequest="400">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="2*, 1.5*, 1.5*, 2*, 3*" RowDefinitions="Auto, 1" Padding="10">
                                
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding Timestamp}" TextColor="#4B5563" VerticalOptions="Center"/>
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding SpO2}" TextColor="#1E40AF" FontAttributes="Bold" VerticalOptions="Center"/>
                                <Label Grid.Row="0" Grid.Column="2" Text="{Binding BPM}" TextColor="#991B1B" FontAttributes="Bold" VerticalOptions="Center"/>
                                <Label Grid.Row="0" Grid.Column="3" Text="{Binding NNProbability}" TextColor="#B45309" VerticalOptions="Center"/>
                                <Label Grid.Row="0" Grid.Column="4" Text="{Binding FuzzyStatus}" TextColor="{Binding StatusColor}" FontAttributes="Bold" VerticalOptions="Center"/>
                                
                                <BoxView Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Color="#E5E7EB" HeightRequest="1" VerticalOptions="End"/>
                                
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="Belum ada data anomali yang terekam." HorizontalOptions="Center" VerticalOptions="Center" TextColor="#9CA3AF" Margin="0,50,0,0"/>
                    </CollectionView.EmptyView>
                </CollectionView>

            </VerticalStackLayout>
        </Border>

    </VerticalStackLayout>
</ContentPage>