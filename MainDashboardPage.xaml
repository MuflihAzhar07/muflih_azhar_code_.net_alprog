<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VitalGuard.MainDashboardPage"
             Title="VitalGuard - Dashboard Medis"
             BackgroundColor="#F3F4F6">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Border BackgroundColor="White" Padding="15" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                <FlexLayout JustifyContent="SpaceBetween" AlignItems="Center">
                    <VerticalStackLayout>
                        <Label x:Name="LblWelcome" Text="Selamat Datang, User!" FontSize="20" FontAttributes="Bold" TextColor="#1F2937"/>
                        <Label x:Name="LblRoleBadge" Text="Role: Dokter" FontSize="12" FontAttributes="Bold" TextColor="White" BackgroundColor="#2563EB" Margin="0,5,0,0" Padding="8,3"/>
                    </VerticalStackLayout>
                    <Button Text="Logout" BackgroundColor="#EF4444" TextColor="White" CornerRadius="8" HeightRequest="35" Clicked="OnLogoutClicked"/>
                </FlexLayout>
            </Border>

            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="20" RowSpacing="20">

                <Border Grid.Column="0" Grid.Row="0" BackgroundColor="White" Padding="20" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Pemantauan Tanda Vital" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>

                        <Grid ColumnDefinitions="*, Auto" BackgroundColor="#EFF6FF" Padding="15" Margin="0,5">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="Saturasi Oksigen (SpO2)" FontSize="13" TextColor="#1E40AF"/>
                                <Label x:Name="TxtSpO2" Text="98 %" FontSize="28" FontAttributes="Bold" TextColor="#1E3A8A"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="🫁" FontSize="32" VerticalOptions="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*, Auto" BackgroundColor="#FEF2F2" Padding="15">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="Detak Jantung (BPM)" FontSize="13" TextColor="#991B1B"/>
                                <Label x:Name="TxtBPM" Text="75 BPM" FontSize="28" FontAttributes="Bold" TextColor="#7F1D1D"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="❤️" FontSize="32" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" Grid.Row="0" BackgroundColor="White" Padding="20" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Analisis Sistem AI Hibrida" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>

                        <VerticalStackLayout Margin="0,5">
                            <Label Text="Probabilitas Anomali (Neural Network):" FontSize="12" TextColor="#4B5563"/>
                            <Label x:Name="TxtNNOutput" Text="2.4% (Normal)" FontSize="16" FontAttributes="Bold" TextColor="#10B981"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Margin="0,0,0,5">
                            <Label Text="Status Klinis Pasien (Fuzzy Inference):" FontSize="12" TextColor="#4B5563"/>
                            <Border x:Name="BorderFuzzy" BackgroundColor="#10B981" Padding="8" StrokeShape="RoundRectangle 6" StrokeThickness="0" HorizontalOptions="Start">
                                <Label x:Name="TxtFuzzyOutput" Text="AMAN / STABIL" FontAttributes="Bold" TextColor="White" FontSize="14"/>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border BackgroundColor="#F9FAFB" Stroke="#E5E7EB" StrokeThickness="1" Padding="20" StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="8">
                    <Label Text="💡 Penjelasan Kondisi Medis (AI NLP Assistant)" FontSize="14" FontAttributes="Bold" TextColor="#1F2937"/>
                    <Label x:Name="TxtNLPExplanation" Text="Menghubungkan ke API AI untuk membaca kondisi pasien..." FontSize="13" TextColor="#4B5563" LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Border>

            <Border x:Name="PanelDokterView" IsVisible="False" BackgroundColor="White" Padding="20" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🩺 Panel Kontrol Klinis (Khusus Dokter)" FontSize="16" FontAttributes="Bold" TextColor="#2563EB"/>
                    <Label Text="Aktivitas Terakhir: Meninjau riwayat grafik PPG pasien dan memeriksa kecenderungan nilai rata-rata SpO2 harian." FontSize="13" TextColor="#4B5563"/>
                    <Button Text="Buka Rekam Medis Elektronik" BackgroundColor="#2563EB" TextColor="White" CornerRadius="8" HorizontalOptions="Start" Clicked="OnBukaRekamMedisClicked"/>
                </VerticalStackLayout>
            </Border>

            <Border x:Name="PanelPasienView" IsVisible="False" BackgroundColor="White" Padding="20" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="👤 Menu Mandiri Pasien" FontSize="16" FontAttributes="Bold" TextColor="#10B981"/>
                    <Label Text="Pastikan perangkat IoMT Anda terpasang dengan baik pada pergelangan tangan untuk mendapatkan pembacaan yang presisi." FontSize="13" TextColor="#4B5563"/>
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Hubungi Dokter" BackgroundColor="#10B981" TextColor="White" CornerRadius="8" Clicked="OnHubungiDokterClicked"/>
                        <Button Grid.Column="1" Text="🚨 TOMBOL SOS" BackgroundColor="#EF4444" TextColor="White" CornerRadius="8" FontAttributes="Bold" Clicked="OnSosClicked"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#FFFBEB" Stroke="#FDE68A" StrokeThickness="1" Padding="20" StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="15">
                    <Label Text="⚙️ Panel Simulasi Sensor IoMT Terintegrasi (Interactive Manipulation)" FontSize="15" FontAttributes="Bold" TextColor="#B45309"/>
                    <Label Text="Gunakan slider di bawah ini untuk mensimulasikan manipulasi input data sensor secara real-time untuk pengujian model AI." FontSize="12" TextColor="#78350F"/>

                    <VerticalStackLayout>
                        <FlexLayout JustifyContent="SpaceBetween">
                            <Label Text="Simulasi Sensor SpO2 (%)" FontSize="13" FontAttributes="Bold" TextColor="#4B5563"/>
                            <Label x:Name="LblSliderSpO2" Text="98%" FontSize="13" FontAttributes="Bold" TextColor="#B45309"/>
                        </FlexLayout>
                        <Slider x:Name="SliderSpO2" Minimum="80" Maximum="100" Value="98" MinimumTrackColor="#F59E0B" ValueChanged="OnSensorSimulatorChanged"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout>
                        <FlexLayout JustifyContent="SpaceBetween">
                            <Label Text="Simulasi Sensor Detak Jantung (BPM)" FontSize="13" FontAttributes="Bold" TextColor="#4B5563"/>
                            <Label x:Name="LblSliderBPM" Text="75 BPM" FontSize="13" FontAttributes="Bold" TextColor="#B45309"/>
                        </FlexLayout>
                        <Slider x:Name="SliderBPM" Minimum="40" Maximum="160" Value="75" MinimumTrackColor="#F59E0B" ValueChanged="OnSensorSimulatorChanged"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>