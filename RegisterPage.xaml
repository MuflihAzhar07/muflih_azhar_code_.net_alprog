<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VitalGuard.RegisterPage"
             BackgroundColor="#F3F4F6">

    <ScrollView VerticalOptions="CenterAndExpand">
        <Border StrokeThickness="0"
                BackgroundColor="White"
                Padding="30"
                Margin="20"
                WidthRequest="420"
                HorizontalOptions="Center"
                StrokeShape="RoundRectangle 12">

            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="10" Opacity="0.05" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="15">

                <Label Text="Registrasi Akun Baru" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center" 
                       TextColor="#1F2937" 
                       Margin="0,0,0,10" />

                <Label Text="Username" TextColor="#4B5563" FontAttributes="Bold" FontSize="14" />
                <Entry x:Name="EntryUsername" 
                       Placeholder="Masukkan username" 
                       BackgroundColor="#F9FAFB" 
                       TextColor="Black"
                       PlaceholderColor="#9CA3AF" />

                <Label Text="Password" TextColor="#4B5563" FontAttributes="Bold" FontSize="14" />
                <Entry x:Name="EntryPassword" 
                       Placeholder="Masukkan password" 
                       IsPassword="True" 
                       BackgroundColor="#F9FAFB" 
                       TextColor="Black"
                       PlaceholderColor="#9CA3AF" />

                <Label Text="Hak Akses (Role)" TextColor="#4B5563" FontAttributes="Bold" FontSize="14" />
                <Picker x:Name="PickerRole" 
                        Title="-- Pilih Role --" 
                        TitleColor="#9CA3AF"
                        BackgroundColor="#F9FAFB" 
                        TextColor="Black" />

                <Label Text="Ambil Foto Wajah untuk Database" 
                       FontAttributes="Bold" 
                       TextColor="#4B5563" 
                       FontSize="14"
                       Margin="0,10,0,0"/>

                <Border HeightRequest="200" 
                        StrokeThickness="1"
                        Stroke="#E5E7EB"
                        BackgroundColor="#E5E7EB"
                        StrokeShape="RoundRectangle 8">
                    <Image x:Name="CameraPreview" Aspect="AspectFill" />
                </Border>

                <Button Text="📷 AMBIL FOTO WAJAH" 
                        BackgroundColor="#F59E0B" 
                        TextColor="White" 
                        FontAttributes="Bold"
                        CornerRadius="8"
                        Clicked="OnCaptureFaceClicked" />

                <Button Text="SIMPAN &amp; DAFTARKAN" 
                        FontAttributes="Bold" 
                        BackgroundColor="#10B981" 
                        TextColor="White" 
                        CornerRadius="8" 
                        Margin="0,15,0,0" 
                        HeightRequest="45"
                        Clicked="OnRegisterClicked" />

                <Button Text="Kembali ke Login" 
                        BackgroundColor="Transparent" 
                        TextColor="#2563EB" 
                        TextTransform="None"
                        Clicked="OnBackToLoginClicked" />

            </VerticalStackLayout>
        </Border>
    </ScrollView>
</ContentPage>